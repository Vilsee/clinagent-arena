# -----------------------------------------------------------------------------
# ClinAgent Arena - Environment Variables
# -----------------------------------------------------------------------------
# This is an example environment file. Copy this to .env.local and fill in
# your specific keys if you choose to implement real API integrations.
# 
# DO NOT COMMIT .env.local TO VERSION CONTROL.
# -----------------------------------------------------------------------------

# Base URL for the site (used for Open Graph metadata)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: LLM API Keys if you choose to wire up /demo to a live evaluator
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
